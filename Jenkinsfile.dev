// Jenkinsfile.dev — CircleGuard Dev Pipeline
// Optimizado para despliegue paralelo y diagnóstico rápido

def SERVICES = [
    'circleguard-auth-service',
    'circleguard-identity-service',
    'circleguard-gateway-service',
    'circleguard-form-service',
    'circleguard-promotion-service',
    'circleguard-notification-service'
]

pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'juan0073'
        K8S_NAMESPACE   = 'cg-dev'
        IMAGE_TAG       = "dev-${BUILD_NUMBER}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 60, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Unit Tests') {
            steps {
                script {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        sh './gradlew test --no-daemon --continue'
                    }
                }
            }
            post {
                always {
                    junit 'services/*/build/test-results/test/*.xml'
                }
            }
        }

        stage('Containerization') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'U', passwordVariable: 'P')]) {
                    sh "echo $P | docker login -u $U --password-stdin"
                    script {
                        def builds = [:]
                        SERVICES.each { svc ->
                            builds[svc] = {
                                sh """
                                    docker build -t ${DOCKER_REGISTRY}/${svc}:${IMAGE_TAG} -t ${DOCKER_REGISTRY}/${svc}:dev-latest -f services/${svc}/Dockerfile .
                                    docker push ${DOCKER_REGISTRY}/${svc}:${IMAGE_TAG}
                                    docker push ${DOCKER_REGISTRY}/${svc}:dev-latest
                                """
                            }
                        }
                        parallel builds
                    }
                }
            }
        }

        stage('Deploy Infrastructure') {
            steps {
                script {
                    docker.image('bitnami/kubectl:latest').inside('--entrypoint="" --network host') {
                        withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                            sh '''
                                export KUBECONFIG=$KUBECONFIG
                                kubectl apply -f k8s/namespaces.yml
                                kubectl apply -f k8s/infra/ -n cg-dev
                                echo "Esperando 30s a que la infraestructura base inicie..."
                                sleep 30
                            '''
                        }
                    }
                }
            }
        }

        stage('Deploy Services (Parallel)') {
            steps {
                script {
                    def rollouts = [:]
                    SERVICES.each { svc ->
                        def shortName = svc.replace('circleguard-', '').replace('-service', '')
                        rollouts[svc] = {
                            docker.image('bitnami/kubectl:latest').inside('--entrypoint="" --network host') {
                                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                                    sh """
                                        export KUBECONFIG=$KUBECONFIG
                                        kubectl apply -f k8s/services/${shortName}-deployment.yml -n cg-dev
                                        kubectl set image deployment/${shortName}-service ${shortName}-service=${DOCKER_REGISTRY}/${svc}:${IMAGE_TAG} -n cg-dev
                                        echo "Verificando rollout de ${shortName}..."
                                        kubectl rollout status deployment/${shortName}-service -n cg-dev --timeout=180s
                                    """
                                }
                            }
                        }
                    }
                    parallel rollouts
                }
            }
            post {
                failure {
                    script {
                        docker.image('bitnami/kubectl:latest').inside('--entrypoint="" --network host') {
                            withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                                sh '''
                                    export KUBECONFIG=$KUBECONFIG
                                    echo "--- DIAGNÓSTICO DE FALLO ---"
                                    kubectl get pods -n cg-dev
                                    kubectl get events -n cg-dev --sort-by=.lastTimestamp | tail -n 15
                                    echo "--- LOGS DE AUTH-SERVICE (REFERENCIA) ---"
                                    kubectl logs -l app=auth-service -n cg-dev --tail=50
                                '''
                            }
                        }
                    }
                }
            }
        }

        stage('Final Health Check') {
            steps {
                script {
                    docker.image('bitnami/kubectl:latest').inside('--entrypoint="" --network host') {
                        withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                            sh '''
                                export KUBECONFIG=$KUBECONFIG
                                kubectl get pods -n cg-dev
                                echo "✅ Todos los servicios están en proceso de ejecución."
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'docker image prune -f --filter "dangling=true" || true'
        }
    }
}
